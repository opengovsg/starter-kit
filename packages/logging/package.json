{
  "name": "@acme/logging",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./tracer": "./src/tracer.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --ignore-path ../../.gitignore .",
    "lint": "oxlint .",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:t3-env",
    "dd-trace": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  }
}
