{
  "name": "@acme/redis",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./testing": {
      "types": "./dist/src/testing.d.ts",
      "default": "./src/testing.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --ignore-path ../../.gitignore .",
    "lint": "oxlint .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:t3-env",
    "ioredis": "^5.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  }
}
