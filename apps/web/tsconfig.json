{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "types": ["vitest/globals"],
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "paths": {
      "~/*": ["./src/*"],
      "~storybook/*": ["./.storybook/*"],
      "~tests/*": ["./tests/*"]
    }
  },
  "include": [".", ".storybook/**/*"],
  "exclude": [
    "node_modules",
    "public/mockServiceWorker.js",
    ".output",
    "coverage",
    "dist",
    "storybook-static"
  ]
}
